# SwimAI Environment Configuration
# Copy this to .env and customize

# Database (if using postgres profile)
DB_PASSWORD=your_secure_password_here

# Gurobi License (if using Gurobi optimization)
# GRB_LICENSE_FILE=/app/gurobi.lic

# API Keys (if needed)
# OPENAI_API_KEY=your_key_here

# Development
REFLEX_ENV=dev
WATCHFILES_FORCE_POLLING=true

# Production
# REFLEX_ENV=prod
# Domain for deployment
# DOMAIN=swimai.yourdomain.com
