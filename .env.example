# =============================================================================
# AquaForge.ai Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=AquaForge.ai                     # Display name
APP_VERSION=1.0.0                          # Semantic version
ENVIRONMENT=development                    # development | staging | production
DEBUG=false                                # Show detailed error messages

# -----------------------------------------------------------------------------
# API Server (FastAPI / Uvicorn)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0                           # Bind address
API_PORT=8001                              # Backend port (Uvicorn)
API_WORKERS=1                              # Uvicorn worker count
# API_KEY=your_secure_api_key              # Future: API key for authenticated endpoints

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1     # V1 API base URL
NEXT_PUBLIC_API_URL_V2=http://localhost:8001/api/v2  # V2 API base URL
NODE_ENV=development                                  # development | production

# -----------------------------------------------------------------------------
# Security & CORS
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production         # JWT / session signing key
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000  # Comma-separated allowed origins
CORS_ALLOW_ALL=true                        # Set false in production

# -----------------------------------------------------------------------------
# Database (optional -- defaults to local SQLite)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/aquaforge
# REDIS_URL=redis://localhost:6379/0

# Docker Compose Postgres shorthand:
# DB_PASSWORD=aquaforge_dev_password

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
UPLOAD_DIR=uploads                         # Directory for uploaded files
MAX_UPLOAD_SIZE_MB=50                      # Max upload size in MB

# -----------------------------------------------------------------------------
# Gurobi Optimizer (optional -- WLS cloud license)
# Required only when using Gurobi engine; AquaOpt works without these.
# -----------------------------------------------------------------------------
# WLSACCESSID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# WLSSECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LICENSEID=123456
# GRB_LICENSE_FILE=/path/to/gurobi.lic     # Alternative: local license file

# -----------------------------------------------------------------------------
# Optimization
# -----------------------------------------------------------------------------
DEFAULT_OPTIMIZER=aquaopt                  # aquaopt | gurobi | heuristic
OPTIMIZATION_TIMEOUT_SECONDS=300           # Max solve time (seconds)
ENABLE_CACHING=true                        # Cache optimization results

# -----------------------------------------------------------------------------
# LLM Advisor (optional -- OpenAI for AI coach suggestions)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Memory Service (Mem0 -- optional)
# -----------------------------------------------------------------------------
# MEM0_ENABLED=true                        # Set false to disable
# MEM0_API_KEY=your_mem0_api_key

# -----------------------------------------------------------------------------
# Email Reports (optional -- SMTP)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# -----------------------------------------------------------------------------
# Error Tracking (Sentry -- optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxxxx@o12345.ingest.sentry.io/12345
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry -- optional)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                            # json | text

# -----------------------------------------------------------------------------
# Deployment / Platform (auto-set by hosting providers)
# -----------------------------------------------------------------------------
# PORT=8080                                # Single-port entry (Caddy) for Railway/Render
# RAILWAY_PUBLIC_DOMAIN=aquaforge.up.railway.app
# RENDER_EXTERNAL_URL=https://aquaforge.onrender.com

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# WATCHFILES_FORCE_POLLING=true            # Required for Docker on Windows/WSL
