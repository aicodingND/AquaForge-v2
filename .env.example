# =============================================================================
# AquaForge.ai Environment Configuration Template
# Copy this file to .env and customize for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# Reflex Cloud Deployment (get from Reflex dashboard)
# -----------------------------------------------------------------------------
REFLEX_PROJECT_ID=your_project_id
REFLEX_APP_ID=your_app_id
REFLEX_APP_NAME=swim_ai_reflex
REFLEX_ACCESS_TOKEN=your_access_token
REFLEX_ENV=dev

# -----------------------------------------------------------------------------
# App Settings
# -----------------------------------------------------------------------------
APP_TITLE=AquaForge
APP_DESCRIPTION=Swim Meet Optimization Platform
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Environment Mode
# -----------------------------------------------------------------------------
ENVIRONMENT=development
NODE_ENV=development
DEBUG=false
CORS_ALLOW_ALL=true

# -----------------------------------------------------------------------------
# GCP / Google Cloud Configuration
# Required for Cloud Run, Firebase, and Vertex AI integrations
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-east5

# -----------------------------------------------------------------------------
# Vertex AI / OpenCode Desktop (Claude via Vertex)
# Required for AI-powered development tools
# -----------------------------------------------------------------------------
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
ANTHROPIC_VERTEX_REGION=us-east5
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-east5

# Direct Anthropic API (alternative to Vertex)
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Frontend API Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL_V2=http://localhost:8000/api/v2

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
UPLOAD_DIR=uploads
API_HOST=0.0.0.0
API_PORT=8000
# API_KEY=your_secure_api_key

# -----------------------------------------------------------------------------
# Database (PostgreSQL - optional)
# -----------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=aquaforge
# DB_USER=aquaforge
# DB_PASSWORD=your_secure_password

# -----------------------------------------------------------------------------
# Gurobi Optimizer License (for advanced optimization)
# -----------------------------------------------------------------------------
# GRB_LICENSE_FILE=/path/to/gurobi.lic

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
WATCHFILES_FORCE_POLLING=true

# -----------------------------------------------------------------------------
# Production Deployment
# -----------------------------------------------------------------------------
# ENVIRONMENT=production
# NODE_ENV=production
# DOMAIN=aquaforge.yourdomain.com
