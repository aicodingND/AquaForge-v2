# AquaForge — Caddy reverse proxy
# Serves Next.js static frontend + proxies API to FastAPI

:{$PORT:8080} {

    # Health checks — immediate response (no backend dependency)
    handle /health {
        respond "OK" 200
    }
    handle /ping {
        respond "pong" 200
    }

    # API proxy → FastAPI on localhost:8001
    handle /api/* {
        reverse_proxy localhost:8001 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Coach data files
    handle /data_guide.html {
        root * /app/assets
        file_server
    }
    handle /Seton_Team_Template.csv {
        root * /app/assets
        file_server
    }
    handle /Opponent_Team_Template.csv {
        root * /app/assets
        file_server
    }

    # Frontend SPA — must be last
    handle {
        root * /app/frontend-build
        try_files {path} {path}.html {path}/ /index.html
        file_server
    }

    log {
        output stdout
        format console
        level INFO
    }
}
